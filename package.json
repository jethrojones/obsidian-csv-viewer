{
  "name": "obsidian-csv-viewer",
  "version": "1.3.1",
  "description": "View and edit CSV files, and inspect log files with filtering.",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "lint:obsidian": "eslint main.ts csv-parser.ts csv-parser.test.ts",
    "verify": "npm run lint:obsidian && npm run build && npm test",
    "hooks:install": "git config core.hooksPath .githooks",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "obsidian",
    "csv",
    "log",
    "viewer"
  ],
  "author": "Life Lab",
  "license": "MIT",
  "devDependencies": {
    "@emnapi/core": "^1.10.0",
    "@emnapi/runtime": "^1.10.0",
    "@types/node": "^20.19.35",
    "@typescript-eslint/parser": "^8.59.3",
    "esbuild": "0.28.0",
    "eslint": "^9.39.4",
    "eslint-plugin-obsidianmd": "^0.3.0",
    "obsidian": "latest",
    "tslib": "2.4.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
