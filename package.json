{
  "name": "obsidian-csv-viewer",
  "version": "1.1.0",
  "description": "View CSV files directly in Obsidian",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "obsidian",
    "csv",
    "viewer"
  ],
  "author": "Life Lab",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.19.35",
    "builtin-modules": "^3.3.0",
    "esbuild": "0.17.3",
    "obsidian": "latest",
    "tslib": "2.4.0",
    "typescript": "4.7.4",
    "vitest": "^4.0.18"
  }
}
